{
  "author": "Ahmed Sami",
  "description": "A simple web app for creating and sharing LaTeX documents",
  "name": "ltx",
  "version": "0.3.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "lint": "next lint",
    "format": "prettier \"./**/*.{css,js,jsx,cjs,mjs,ts,tsx,md,mdx,json}\"",
    "format:write": "prettier --write \"./**/*.{css,js,jsx,cjs,mjs,ts,tsx,md,mdx,json}\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "rm -rf node_modules && rm -rf .next",
    "postinstall": "prisma generate"
  },
  "dependencies": {
