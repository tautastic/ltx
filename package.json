    "@prisma/client": "^4.11.0",
    "@radix-ui/react-accordion": "^1.1.1",
    "@radix-ui/react-alert-dialog": "^1.0.3",
    "@tanstack/react-query": "^4.26.1",
    "@trpc/client": "^10.14.1",
    "@trpc/next": "^10.14.1",
    "@trpc/react-query": "^10.14.1",
    "@trpc/server": "^10.14.1",
    "nanoid": "^4.0.1",
    "next": "^13.2.3",
    "next-auth": "^4.20.1",
    "next-seo": "^5.15.0",
    "next-themes": "^0.2.1",
    "nextjs-progressbar": "^0.0.16",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-toastify": "^9.1.1",
    "sharp": "^0.31.3",
    "superjson": "^1.12.2",
